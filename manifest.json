{
  "manifest_version": 3,
  "name": "나무위키 게임",
  "version": "1.0.2",
  "description": "나무위키 링크를 클릭해서 목표 문서까지 도달하는 멀티플레이 게임",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://namu.wiki/*",
    "https://following-stace-alpacadash-f96a56ec.koyeb.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://namu.wiki/w/*"],
      "js": ["config.js", "socket.io.min.js", "content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "나무위키 게임",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["config.js", "socket.io.min.js"],
      "matches": ["https://namu.wiki/*"]
    }
  ]
}
